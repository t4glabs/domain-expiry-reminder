# Copy this file to .env and fill in your values.
# .env is gitignored and never committed.

# -------------------------------------------------------
# Notification platform toggles
# Set to true to enable a platform, false to disable it.
# CLI flags (-t, -g, -e, -ssl, -auth, -starttls) still
# override these if passed on the command line.
# -------------------------------------------------------
ENABLE_TELEGRAM=false
ENABLE_GOOGLE_CHAT=false

# For email: set the recipient address to enable it.
# Leave blank to disable email notifications.
EMAIL_TO=

# -------------------------------------------------------
# Email method flags
# Only one of ENABLE_EMAIL_SSL or ENABLE_EMAIL_STARTTLS
# should be true at a time (they are mutually exclusive).
#
# Gmail (App Password):
#   SMTP_SERVER=smtp.gmail.com
#   SMTP_PORT=587
#   ENABLE_EMAIL_STARTTLS=true
#   ENABLE_EMAIL_AUTH=true
#   SMTP_SENDER=you@gmail.com
#   SMTP_PASSWORD=<16-char app password from myaccount.google.com/apppasswords>
#
# Mailgun (SMTP):
#   SMTP_SERVER=smtp.mailgun.org
#   SMTP_PORT=587
#   ENABLE_EMAIL_STARTTLS=true
#   ENABLE_EMAIL_AUTH=true
#   SMTP_SENDER=postmaster@mg.yourdomain.com
#   SMTP_PASSWORD=<Mailgun SMTP password from sending domains page>
#
# Generic SSL (port 465):
#   SMTP_PORT=465
#   ENABLE_EMAIL_SSL=true
#   ENABLE_EMAIL_AUTH=true
# -------------------------------------------------------
ENABLE_EMAIL_SSL=false
ENABLE_EMAIL_AUTH=false
ENABLE_EMAIL_STARTTLS=false

# -------------------------------------------------------
# SMTP settings
# -------------------------------------------------------
SMTP_SERVER=localhost
SMTP_PORT=25
SMTP_SENDER=root
SMTP_PASSWORD=
# Set to 0 to disable SSL hostname verification for SMTP
SMTP_CHECK_SSL_HOSTNAME=1

# -------------------------------------------------------
# Telegram settings (used when ENABLE_TELEGRAM=true)
# Get your token from @BotFather on Telegram
# -------------------------------------------------------
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# -------------------------------------------------------
# Google Chat settings (used when ENABLE_GOOGLE_CHAT=true)
# Get from: https://developers.google.com/workspace/chat/quickstart/webhooks
# -------------------------------------------------------
GOOGLE_CHAT_WEBHOOK=
